# Obsidian local state (workspace, plugins, etc.)
.obsidian/

# Dynamic vault state (auto-updated by /fetch-sources, local only)
.vault-state.yml
.vault-state.yml.lock

# Audit reports (generated artefacts, not vault content)
audit/audit-*.md

# Fetch summaries (generated by /fetch-sources --summary full, ephemeral)
digest/*-fetch-summary.md
!digest/.gitkeep

# Daily digests (generated by /daily-digest, ephemeral)
journal/*-digest.md
!journal/.gitkeep

# OS / editor noise
.DS_Store
*.swp
*~
.idea/
.vscode/
